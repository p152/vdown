BOT_TOKEN=

# https://my.telegram.org — required for local Telegram Bot API
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

VIDBEE_API_URL=http://vidbee-api:3100
TELEGRAM_BOT_API_URL=http://telegram-bot-api:8081
DOWNLOADS_DIR=/data/downloads

REDIS_URL=redis://redis:6379/0

# PostgreSQL
POSTGRES_PASSWORD=vdown_secret
DATABASE_URL=postgresql+asyncpg://vdown:vdown_secret@postgres:5432/vdown

# Auto-download short videos without format selection
AUTO_MAX_DURATION_SEC=180
AUTO_MAX_SIZE_MB=100
MAX_CONCURRENT_DOWNLOADS=3

# Optional VidBee proxy (e.g. socks5://127.0.0.1:1080)
VIDBEE_PROXY=

# Path to Instagram cookies inside containers
VIDBEE_COOKIES_PATH=/data/cookies/cookies.txt

# Telegram user IDs allowed to upload cookies and access admin (comma-separated)
ADMIN_IDS=

# Chat ID for bug reports (optional; falls back to ADMIN_IDS)
FEEDBACK_CHAT_ID=

# Freemium: free downloads per day
FREE_DAILY_LIMIT=5

# Crypto Bot (@CryptoBot) API token
CRYPTO_BOT_TOKEN=

# Public URL of admin panel (for webhooks). Port must match API_PORT below.
WEB_BASE_URL=http://localhost:8082

# Host port for web admin (container always listens on 8080)
API_PORT=8082

# Admin web panel auth
JWT_SECRET=change-me-in-production
ADMIN_WEB_PASSWORD=
